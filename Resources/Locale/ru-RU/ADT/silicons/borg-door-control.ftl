# Названия функций клавиш (отображаются в меню настроек управления).
# Ключ строится из BoundKeyFunction через PascalToKebab.
ui-options-function-adt-borg-bolt-door = Заболтировать/разболтировать шлюз (борг)
ui-options-function-adt-borg-electrify-door = Электризовать/обесточить шлюз (борг)
ui-options-function-adt-borg-emergency-door = Переключить аварийный доступ (борг)
ui-options-function-adt-borg-toggle-door = Открыть/закрыть шлюз (борг)

# Попапы при неудачном действии борга.
borg-door-control-out-of-range = Слишком далеко!
borg-door-control-not-supported = Этот шлюз не поддерживает данное действие.
borg-door-control-not-responding = Шлюз обесточен или повреждён.
borg-door-control-no-access = Доступ запрещён.

# Подсказки радиального меню для открытия/закрытия.
borg-door-control-open = Открыть шлюз
borg-door-control-close = Закрыть шлюз
