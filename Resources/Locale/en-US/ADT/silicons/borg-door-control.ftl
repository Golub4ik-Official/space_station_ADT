# Keybind function display names (shown in the controls settings menu).
# The lookup key is built from the BoundKeyFunction string via PascalToKebab.
ui-options-function-adt-borg-bolt-door = Bolt/unbolt door (borg)
ui-options-function-adt-borg-electrify-door = Electrify/unelectrify door (borg)
ui-options-function-adt-borg-emergency-door = Toggle emergency access (borg)
ui-options-function-adt-borg-toggle-door = Open/close door (borg)

