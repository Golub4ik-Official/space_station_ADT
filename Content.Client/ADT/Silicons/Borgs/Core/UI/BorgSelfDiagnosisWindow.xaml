<controls:FancyWindow xmlns="https://spacestation14.io"
    xmlns:gfx="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
    xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
    Title="Cyborg Self-Diagnosis"
    MinSize="350 300"
    SetSize="350 400">

    <ScrollContainer VerticalExpand="True"
                    HScrollEnabled="False">
        <BoxContainer Orientation="Vertical"
                    VerticalExpand="True"
                    Margin="5 5 5 5">

            <Label Name="StatusHeader"
                Text="=== SYSTEM STATUS ==="
                FontColorOverride="Cyan"
                Margin="0 0 0 5"/>

            <Label Name="BatteryLabel"
                Text="Cell: N/A"
                Margin="0 2 0 2"/>

            <Label Name="LawLabel"
                Text="Laws: N/A"
                Margin="0 2 0 2"/>

            <Label Name="LockLabel"
                Text="Lock: N/A"
                Margin="0 2 0 5"/>

            <Label Name="PartsHeader"
                Text="=== COMPONENT INTEGRITY ==="
                FontColorOverride="Cyan"
                Margin="0 5 0 5"/>

            <BoxContainer Name="PartsContainer"
                        Orientation="Vertical"
                        VerticalExpand="True"/>

            <Label Name="WiresHeader"
                Text="=== WIRE STATUS ==="
                FontColorOverride="Cyan"
                Margin="0 5 0 5"/>

            <BoxContainer Name="WiresContainer"
                        Orientation="Vertical"
                        VerticalExpand="True"/>

        </BoxContainer>
    </ScrollContainer>
</controls:FancyWindow>
